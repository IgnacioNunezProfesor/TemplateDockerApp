DB_CONTAINER_NAME=db_mysql_dev
DB_DOCKERFILE=./docker/bd/mysql.dev.dockerfile
DB_IMAGE_NAME=db_mysql:dev


DB_UNIX_USER=user

#DB_NAME=db_moodle_dev
#DB_USER=dbuser
#DB_PASS=1234

DB_PORT=3306
DB_ROOT_PASS=123456

DB_SERVER_DATADIR=/var/lib/mysql
DB_LOCAL_DATA_DIR=./data/db/mysql_dev

DB_SERVER_LOG=/var/log/mysql
DB_LOCAL_LOG=./logs/db/mysql_dev

DB_NETWORK_DRIVER=bridge
DB_NETWORK_NAME=MyMoodleNet
DB_NETWORK_SUBNET=192.168.1.0/24
DB_NETWORK_SUBNET_GATEWAY=192.168.1.1
DB_IP=192.168.1.40